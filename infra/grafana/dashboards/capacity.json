{
  "title": "Talky / Capacity",
  "uid": "talky-capacity",
  "tags": ["talky", "phase3"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(talky_active_calls, namespace)",
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Cluster active calls",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(talky_active_calls{namespace=\"$namespace\"})",
          "legendFormat": "active",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Cluster capacity (sum of pod caps)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(talky_pod_capacity{namespace=\"$namespace\"})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Cluster saturation %",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "100 * sum(talky_active_calls{namespace=\"$namespace\"}) / sum(talky_pod_capacity{namespace=\"$namespace\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100, "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 85 }
          ] }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Pods ready",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "count(talky_active_calls{namespace=\"$namespace\"})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Active calls per pod",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "talky_active_calls{namespace=\"$namespace\"}",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Provider in-flight vs cap",
      "description": "From the Phase 1 ProviderConcurrencyGuard. Yellow line is the per-provider cap.",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "talky_provider_inflight{namespace=\"$namespace\"}",
          "legendFormat": "{{provider}} in-flight",
          "refId": "A"
        },
        {
          "expr": "talky_provider_max_concurrent{namespace=\"$namespace\"}",
          "legendFormat": "{{provider}} cap",
          "refId": "B"
        }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Provider saturation %",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "100 * talky_provider_inflight{namespace=\"$namespace\"} / talky_provider_max_concurrent{namespace=\"$namespace\"}",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 85 }
          ] }
        }
      }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Provider key-pool key health",
      "description": "Cooldown count and EWMA error rate per key. Pools with all keys cooling go red.",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "talky_keypool_keys_cooling{namespace=\"$namespace\"}",
          "legendFormat": "{{provider}} cooling",
          "refId": "A"
        }
      ]
    }
  ]
}
