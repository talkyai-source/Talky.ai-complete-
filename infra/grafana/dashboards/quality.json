{
  "title": "Talky / Call quality",
  "uid": "talky-quality",
  "tags": ["talky", "phase3"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(talky_active_calls, namespace)",
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Barge-in detection latency (p95)",
      "description": "Time between caller speech onset and AI TTS interrupt.",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(talky_bargein_latency_seconds_bucket{namespace=\"$namespace\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 0.15 },
            { "color": "red", "value": 0.3 }
          ] }
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Audio queue overruns / sec",
      "description": "Caller audio dropped because the STT pipeline couldn't keep up. Should be 0.",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(talky_audio_queue_overrun_total{namespace=\"$namespace\"}[1m])) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "TTS frames dropped (gap > 150ms) / sec",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(talky_tts_frame_drop_total{namespace=\"$namespace\"}[1m])) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Calls accepted / rejected (503)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(talky_calls_accepted_total{namespace=\"$namespace\"}[1m]))",
          "legendFormat": "accepted",
          "refId": "A"
        },
        {
          "expr": "sum(rate(talky_calls_rejected_total{namespace=\"$namespace\",reason=\"capacity\"}[1m]))",
          "legendFormat": "503 capacity",
          "refId": "B"
        },
        {
          "expr": "sum(rate(talky_calls_rejected_total{namespace=\"$namespace\",reason=\"draining\"}[1m]))",
          "legendFormat": "503 drain",
          "refId": "C"
        }
      ]
    }
  ]
}
