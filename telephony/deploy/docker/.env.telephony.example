# WS-A staging defaults.
# Best practice: pin immutable image digests before production use.

# Official Kamailio package moved to GHCR.
# Example pinned tag from upstream package listing.
KAMAILIO_IMAGE=ghcr.io/kamailio/kamailio:6.0.4-bookworm
# rtpengine is built locally from Dockerfile by default.
RTPENGINE_IMAGE=talky/rtpengine:ubuntu24.04
# Public bootstrap image. Replace with your pinned enterprise image in production.
FREESWITCH_IMAGE=safarov/freeswitch:latest

KAMAILIO_SIP_IP=0.0.0.0
KAMAILIO_SIP_PORT=15060
KAMAILIO_TLS_PORT=15061
KAMAILIO_TLS_ONLY=0
KAMAILIO_CANARY_ENABLED=0
KAMAILIO_CANARY_PERCENT=0
KAMAILIO_CANARY_FREEZE=0
FREESWITCH_SIP_PORT=5080
FREESWITCH_ESL_PORT=8021
FREESWITCH_ESL_PASSWORD=ClueCon

RTPENGINE_NG_PORT=2223
RTP_PORT_MIN=30000
RTP_PORT_MAX=30100
