# group ip_addr mask port tag
# WS-B trusted source baseline:
# - loopback
# - RFC1918 private address space
# - carrier-grade NAT range (100.64/10)

1 127.0.0.1 32 0 loopback-v4
1 [::1] 128 0 loopback-v6
1 10.0.0.0 8 0 private-10
1 172.16.0.0 12 0 private-172
1 192.168.0.0 16 0 private-192
1 100.64.0.0 10 0 cgnat
