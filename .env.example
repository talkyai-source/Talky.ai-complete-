# ============================================================
# Root-level environment for `docker compose up`.
# Copy to `.env`  (in repo root) and fill in real values.
# These are consumed by docker-compose.yml ONLY.
# Application-level config lives in backend/.env (see backend/.env.example).
# ============================================================

# Postgres
POSTGRES_DB=talky
POSTGRES_USER=talky
POSTGRES_PASSWORD=change-me-strong-random-string

# Redis
REDIS_PASSWORD=change-me-another-strong-random-string

# Backend
ENVIRONMENT=production
LOG_LEVEL=INFO
BACKEND_PORT=8000
