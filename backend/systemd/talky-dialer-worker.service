[Unit]
Description=Talky.ai Dialer Worker
After=network.target redis.service talky-api.service
Requires=redis.service

[Service]
Type=exec
WorkingDirectory=/home/ai-lab/Desktop/Talky.ai-complete-/backend
EnvironmentFile=/home/ai-lab/Desktop/Talky.ai-complete-/backend/.env
ExecStart=/home/ai-lab/Desktop/Talky.ai-complete-/backend/venv/bin/python -m app.workers.dialer_worker
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=talky-dialer

[Install]
WantedBy=multi-user.target
