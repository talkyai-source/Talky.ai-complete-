[Unit]
Description=Talky.ai Voice Pipeline Worker
After=network.target talky-api.service

[Service]
Type=exec
WorkingDirectory=/opt/talky/backend
EnvironmentFile=/opt/talky/backend/.env
ExecStart=/opt/talky/backend/venv/bin/python -m app.workers.voice_worker
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=talky-voice

[Install]
WantedBy=multi-user.target
