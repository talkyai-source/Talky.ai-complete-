# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Environment
ENVIRONMENT=development

# STT Providers
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# TTS Providers
CARTESIA_API_KEY=your_cartesia_api_key_here

# Google Cloud TTS Streaming (Chirp3-HD) - Choose ONE of these auth methods:
# Option 1: Paste your service account JSON directly (recommended for simplicity)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project",...}

# Option 2: Point to a service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=config/google-service-account.json

# Option 3: For local dev, run: gcloud auth application-default login

# LLM Providers
GROQ_API_KEY=your_groq_api_key_here

# Telephony
VONAGE_API_KEY=your_vonage_api_key_here
VONAGE_API_SECRET=your_vonage_api_secret_here
VONAGE_APP_ID=your_vonage_app_id_here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/voice_dialer
RECORDINGS_STORAGE_DIR=audio_files/storage

# JWT Verification (Required for production)
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256

# Telephony observability (/metrics)
# Optional: if set, Prometheus must send X-Metrics-Token header with this value.
TELEPHONY_METRICS_TOKEN=
# SLO aggregation window (minutes), clamped to [5, 10080]
TELEPHONY_METRICS_WINDOW_MINUTES=60

# Redis
REDIS_URL=redis://localhost:6379

# Application
SECRET_KEY=your_secret_key_here_change_in_production

# Voice Pipeline (RTP)
RTP_REMOTE_IP=127.0.0.1
RTP_REMOTE_PORT=5004
RTP_LOCAL_PORT=5005
RTP_CODEC=ulaw
TTS_SOURCE_SAMPLE_RATE=24000

# FreeSWITCH ESL
FREESWITCH_ESL_HOST=127.0.0.1
FREESWITCH_ESL_PORT=8021
FREESWITCH_ESL_PASSWORD=ClueCon

# Workers
TTS_PROVIDER=google
MEDIA_GATEWAY_TYPE=rtp
WORKER_LOG_LEVEL=INFO
MAX_CONCURRENT_PIPELINES=50
