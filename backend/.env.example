# ============================================================================
# Talky.ai — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to git

# ============================================================================
# Email Service Configuration (Microsoft 365 / GoDaddy)
# ============================================================================

# Sender email address
# For talkleeai.com: noreply@talkleeai.com
EMAIL_USER=noreply@talkleeai.com

# Microsoft 365 password or App Password
# If MFA is enabled on the account, use an App Password from:
# https://account.microsoft.com/security > App passwords
# Format: "xxxx xxxx xxxx xxxx" (16 characters, spaces can be removed)
EMAIL_PASS=your_app_password_or_m365_password

# ============================================================================
# AI Provider API Keys
# ============================================================================

# STT Providers
DEEPGRAM_API_KEY=your_deepgram_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# LLM Providers
GROQ_API_KEY=your_groq_api_key_here
# Google Gemini (Gemini 2.5 Flash; will also serve Gemma 4 once available via
# AI Studio). Leave unset to hide the Gemini option from the AI Options UI.
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================================
# Application URLs
# ============================================================================

# Frontend URL for verification email links
# Used to construct verification URLs in emails
FRONTEND_URL=https://talkleeai.com

# Backend API base URL
# Used to construct verification link in email
API_BASE_URL=https://api.talkleeai.com

# ============================================================================
# Database Configuration
# ============================================================================

# PostgreSQL database connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://talkyai:REPLACE_WITH_STRONG_DB_PASSWORD@localhost:5432/talkyai

# ============================================================================
# Authentication & Security
# ============================================================================

# JWT secret for signing tokens
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_long_random_secret_key_here_at_least_32_chars

# Alternative secret key (legacy)
SECRET_KEY=your_alternative_secret_key_here

# Master encryption key for sensitive data
MASTER_KEY=your_master_encryption_key_here

# Connector OAuth tokens must use a stable Fernet key on every backend pod.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONNECTOR_ENCRYPTION_KEY=REPLACE_WITH_GENERATED_FERNET_KEY

# During key rotation, put prior Fernet keys here as a comma-separated list.
# Keep them until every stored connector token has been re-encrypted with the
# current key. Leave empty when there are no prior keys.
CONNECTOR_ENCRYPTION_KEYS_OLD=

# Shared Google OAuth application used by Gmail, Calendar, and Drive.
# Configure the matching callback URI in Google Cloud Console.
GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_OAUTH_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_GOOGLE_OAUTH_CLIENT_SECRET

# Session lifetime in hours
SESSION_LIFETIME_HOURS=24

# ============================================================================
# Environment Settings
# ============================================================================

# Environment: development, staging, production
ENVIRONMENT=production

# Debug mode (false in production)
DEBUG=false

# ============================================================================
# Optional: Logging & Monitoring
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# Optional: Rate Limiting & Security
# ============================================================================

# Redis URL for rate limiting and caching
REDIS_URL=redis://localhost:6379

# ============================================================================
# Voice Pipeline (RTP)
# ============================================================================
# RTP_CODEC controls the legacy raw-RTP path (not used on FreeSWITCH or the
# Asterisk + C++ Voice Gateway path). The C++ gateway negotiates its own
# codec and stays at PCMU 8kHz on the wire; we upsample to 16kHz internally
# for Deepgram Flux. Leave this as ulaw unless you know you need otherwise.
RTP_REMOTE_IP=127.0.0.1
RTP_REMOTE_PORT=5004
RTP_LOCAL_PORT=5005
RTP_CODEC=ulaw
# TTS_SOURCE_SAMPLE_RATE: rate the TTS provider should synthesize at.
# 16000 Hz matches the new telephony internal rate (Flux native) and avoids
# a redundant downsample step. Use 24000 only for browser-only deployments
# where you want extra TTS richness on headphones.
TTS_SOURCE_SAMPLE_RATE=16000

# FreeSWITCH ESL
FREESWITCH_ESL_HOST=127.0.0.1
FREESWITCH_ESL_PORT=8021
FREESWITCH_ESL_PASSWORD=ClueCon

# ============================================================================
# Internal service-to-service auth (architecture roadmap item 3)
# ----------------------------------------------------------------------------
# Shared secret the dialer worker sends as X-Internal-Service-Token when it
# calls the API process to originate a call (POST /sip/telephony/call). The
# CSRF middleware exempts requests carrying a valid token, so the dialer no
# longer has to spoof a browser Origin header. MUST be identical in the
# talky-api and talky-dialer-worker environments. Generate with e.g.
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# If unset, the originate call is CSRF-rejected (fail-safe).
INTERNAL_SERVICE_TOKEN=

# ============================================================================
# Telephony per-call state backend (architecture roadmap item 1, Phase 1)
# ----------------------------------------------------------------------------
# memory (default) — per-call state lives only in this process. A restart
#   drops every in-flight call. Identical to historical behaviour.
# redis           — mirrors a call-ownership ledger to Redis so a process
#   restart recovers in-flight calls: the successor hangs them up and records
#   the terminal state instead of leaving zombies. Requires REDIS_URL.
#
# Roll out by deploying with =memory (no change), then flipping to =redis.
# Kill-switch rollback is just: set =memory and restart talky-api — no deploy.
TELEPHONY_STATE_BACKEND=memory
# POD_ID — optional human-readable prefix for this process's heartbeat key
# (telephony:pod:{POD_ID}:{short-uuid}:heartbeat). Defaults to the hostname.
# Identity is always made unique per process; this only affects readability.
# POD_ID=

# Workers
TTS_PROVIDER=google
MEDIA_GATEWAY_TYPE=rtp
WORKER_LOG_LEVEL=INFO
MAX_CONCURRENT_PIPELINES=50
