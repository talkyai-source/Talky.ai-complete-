<?xml version="1.0" encoding="utf-8"?>
<!--
  Internal SIP Profile
  For local SIP devices and internal calls
-->
<profile name="internal">
  <settings>
    <!-- SIP Binding -->
    <param name="sip-ip" value="$${local_ip_v4}"/>
    <param name="sip-port" value="$${internal_sip_port}"/>
    <param name="rtp-ip" value="$${local_ip_v4}"/>
    
    <!-- External IPs for NAT traversal -->
    <param name="ext-rtp-ip" value="$${external_rtp_ip}"/>
    <param name="ext-sip-ip" value="$${external_sip_ip}"/>
    
    <!-- RTP Settings -->
    <param name="rtp-timeout-sec" value="300"/>
    <param name="rtp-hold-timeout-sec" value="1800"/>
    <param name="rtp-timer-name" value="soft"/>
    
    <!-- NAT Traversal -->
    <param name="aggressive-nat-detection" value="true"/>
    <param name="local-network-acl" value="localnet.auto"/>
    <param name="apply-nat-acl" value="nat.auto"/>
    
    <!-- Codecs -->
    <param name="inbound-codec-prefs" value="PCMU,PCMA"/>
    <param name="outbound-codec-prefs" value="PCMU,PCMA"/>
    
    <!-- DTMF -->
    <param name="dtmf-type" value="rfc2833"/>
    <param name="rfc2833-pt" value="101"/>
    
    <!-- Session Timers (prevent 6-second drops) -->
    <param name="enable-timer" value="true"/>
    <param name="session-timeout" value="1800"/>
    <param name="minimum-session-expires" value="90"/>
    
    <!-- Context for inbound calls -->
    <param name="context" value="public"/>
    <param name="dialplan" value="XML"/>
    
    <!-- User Agent -->
    <param name="user-agent-string" value="Talky.ai FreeSWITCH"/>
    
    <!-- Debug -->
    <param name="debug" value="0"/>
    <param name="sip-trace" value="no"/>
  </settings>
</profile>
