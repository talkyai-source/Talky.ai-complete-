<?xml version="1.0" encoding="utf-8"?>
<!--
  External SIP Profile
  For registering with 3CX PBX as extension 1001
  
  IMPORTANT: rtp-timeout-sec and rtp-hold-timeout-sec set high
  to prevent PBX from dropping parked/held calls.
  send-silence-when-idle generates comfort noise RTP to keep
  media path alive.
-->
<profile name="external">
  <gateways>
    <!-- 3CX PBX Gateway - Register as AI Agent extension -->
    <gateway name="3cx-pbx">
      <param name="username" value="$${ai_extension}"/>
      <param name="password" value="$${ai_password}"/>
      <param name="realm" value="$${pbx_domain}"/>
      <param name="proxy" value="$${pbx_host}:$${pbx_port}"/>
      <param name="register" value="true"/>
      <param name="register-transport" value="udp"/>
      <param name="retry-seconds" value="30"/>
      <param name="expire-seconds" value="300"/>
      <param name="caller-id-in-from" value="true"/>
      <param name="from-user" value="$${ai_extension}"/>
      <param name="from-domain" value="$${pbx_domain}"/>
      <param name="extension" value="$${ai_extension}"/>
      <param name="context" value="public"/>
    </gateway>
  </gateways>
  
  <settings>
    <!-- SIP Binding for External (different port to avoid conflict) -->
    <param name="sip-ip" value="$${local_ip_v4}"/>
    <param name="sip-port" value="$${external_sip_port}"/>
    <param name="rtp-ip" value="$${local_ip_v4}"/>
    
    <!-- External IPs for NAT -->
    <param name="ext-rtp-ip" value="$${external_rtp_ip}"/>
    <param name="ext-sip-ip" value="$${external_sip_ip}"/>
    
    <!-- RTP Timeout Settings - Set very high to prevent drops -->
    <param name="rtp-timeout-sec" value="3600"/>
    <param name="rtp-hold-timeout-sec" value="3600"/>
    
    <!-- CRITICAL: Generate comfort noise to keep RTP flowing -->
    <!-- This prevents the PBX from thinking the call died -->
    <param name="send-silence-when-idle" value="400"/>
    <param name="suppress-cng" value="false"/>
    
    <!-- NAT Settings -->
    <param name="aggressive-nat-detection" value="true"/>
    <param name="NDLB-force-rport" value="true"/>
    <param name="NDLB-received-in-nat-reg-contact" value="true"/>
    
    <!-- Codecs matching PBX (PCMU = G.711 μ-law) -->
    <param name="inbound-codec-prefs" value="PCMU,PCMA"/>
    <param name="outbound-codec-prefs" value="PCMU,PCMA"/>
    
    <!-- DTMF -->
    <param name="dtmf-type" value="rfc2833"/>
    
    <!-- Session Timers - Keep sessions alive -->
    <param name="enable-timer" value="true"/>
    <param name="session-timeout" value="3600"/>
    <param name="minimum-session-expires" value="120"/>
    
    <!-- Context for inbound calls from PBX -->
    <param name="context" value="public"/>
    <param name="dialplan" value="XML"/>
    
    <!-- User Agent -->
    <param name="user-agent-string" value="Talky.ai FreeSWITCH"/>
  </settings>
</profile>
