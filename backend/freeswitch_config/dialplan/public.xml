<?xml version="1.0" encoding="utf-8"?>
<!--
  Public Dialplan
  Routes incoming calls to AI voice agent.
  
  NOTE: audio_fork is an API command (uuid_audio_fork), NOT a dialplan application.
  The Python ESL client starts audio_fork AFTER the call is established.
-->
<include>
  <context name="public">
    
    <!-- Answer incoming calls to AI agent (ext 1001) and park -->
    <extension name="ai-agent-inbound">
      <condition field="destination_number" expression="^($${ai_extension})$">
        <!-- Log and answer -->
        <action application="log" data="INFO Incoming call to AI Agent from ${caller_id_number}"/>
        <action application="answer"/>
        
        <!-- Set audio parameters -->
        <action application="set" data="playback_terminators=none"/>
        
        <!-- Brief silence to stabilize connection -->
        <action application="sleep" data="500"/>
        
        <!-- Play silence stream to keep call alive while ESL starts audio_fork -->
        <action application="playback" data="silence_stream://-1"/>
      </condition>
    </extension>
    
    <!-- Outbound call to any extension via PBX -->
    <extension name="outbound-via-pbx">
      <condition field="destination_number" expression="^(\d+)$">
        <action application="log" data="INFO Outbound call to ${destination_number} via 3CX PBX"/>
        <action application="set" data="hangup_after_bridge=true"/>
        <action application="set" data="ignore_early_media=true"/>
        
        <!-- Route via 3CX gateway -->
        <action application="bridge" data="sofia/gateway/3cx-pbx/$1"/>
      </condition>
    </extension>
    
  </context>
</include>
