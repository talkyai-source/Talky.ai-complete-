<?xml version="1.0" encoding="utf-8"?>
<!--
  Default Context Dialplan
  Handles local extensions and internal routing
-->
<include>
  <context name="default">
    
    <!-- Echo test extension -->
    <extension name="echo-test">
      <condition field="destination_number" expression="^9196$">
        <action application="answer"/>
        <action application="echo"/>
      </condition>
    </extension>
    
    <!-- Hold music -->
    <extension name="hold-music">
      <condition field="destination_number" expression="^9664$">
        <action application="answer"/>
        <action application="playback" data="$${hold_music}"/>
      </condition>
    </extension>
    
    <!-- Catch-all: route to public context -->
    <extension name="external-calls">
      <condition field="destination_number" expression="^(.+)$">
        <action application="transfer" data="$1 XML public"/>
      </condition>
    </extension>
    
  </context>
</include>
