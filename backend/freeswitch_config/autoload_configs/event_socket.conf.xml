<?xml version="1.0" encoding="utf-8"?>
<!--
  Event Socket Configuration
  Allows Python to control FreeSWITCH via ESL (Event Socket Library)
-->
<configuration name="event_socket.conf" description="Socket Client">
  <settings>
    <!-- Listen on all interfaces for Docker networking -->
    <param name="nat-map" value="false"/>
    <param name="listen-ip" value="$${esl_listen_ip}"/>
    <param name="listen-port" value="$${esl_port}"/>
    <param name="password" value="$${esl_password}"/>
    
    <!-- ACL for security (allow Docker host) -->
    <param name="apply-inbound-acl" value="loopback.auto,lan"/>
    
    <!-- Stop if 3 connections fail -->
    <param name="stop-on-bind-error" value="true"/>
  </settings>
</configuration>
